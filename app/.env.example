# Copy this file to ".env" and fill in your Supabase project values.
# Find them in Supabase → Project Settings → API.
# (The anon key is safe to expose in a frontend app.)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only (powers the AI tab's real chat via /api/ai).
# NOT prefixed with VITE_ so it stays secret and is never sent to the browser.
# Get one at https://console.anthropic.com — add it in Vercel env vars.
ANTHROPIC_API_KEY=sk-ant-...
